<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stock Market Telegram Channel</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      background:#0b1020;
      color:white;
      overflow-x:hidden;
    }

    .hero{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:40px 20px;
      background:
      radial-gradient(circle at top right,#1f3b73 0%,transparent 30%),
      radial-gradient(circle at bottom left,#0f766e 0%,transparent 30%),
      #0b1020;
    }

    .container{
      max-width:1100px;
      width:100%;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:40px;
      align-items:center;
    }

    .left h1{
      font-size:55px;
      line-height:1.1;
      margin-bottom:20px;
      font-weight:700;
    }

    .left h1 span{
      color:#22c55e;
    }

    .left p{
      font-size:18px;
      color:#cbd5e1;
      line-height:1.7;
      margin-bottom:30px;
    }

    .stats{
      display:flex;
      gap:20px;
      margin-bottom:35px;
      flex-wrap:wrap;
    }

    .stat-box{
      background:rgba(255,255,255,0.08);
      padding:18px 25px;
      border-radius:16px;
      backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,0.1);
    }

    .stat-box h3{
      font-size:26px;
      color:#22c55e;
    }

    .stat-box span{
      color:#cbd5e1;
      font-size:14px;
    }

    .telegram-btn{
      display:inline-block;
      padding:18px 40px;
      border-radius:60px;
      text-decoration:none;
      font-size:18px;
      font-weight:600;
      color:white;
      background:linear-gradient(135deg,#2563eb,#06b6d4);
      box-shadow:0 0 25px rgba(37,99,235,0.5);
      transition:0.4s ease;
      position:relative;
      overflow:hidden;
      animation:pulse 2s infinite;
    }

    .telegram-btn:hover{
      transform:translateY(-4px) scale(1.03);
      box-shadow:0 0 35px rgba(6,182,212,0.7);
    }

    .telegram-btn::before{
      content:'';
      position:absolute;
      top:0;
      left:-100%;
      width:100%;
      height:100%;
      background:rgba(255,255,255,0.2);
      transform:skewX(-20deg);
      transition:0.6s;
    }

    .telegram-btn:hover::before{
      left:120%;
    }

    @keyframes pulse{
      0%{
        box-shadow:0 0 0 0 rgba(37,99,235,0.6);
      }
      70%{
        box-shadow:0 0 0 20px rgba(37,99,235,0);
      }
      100%{
        box-shadow:0 0 0 0 rgba(37,99,235,0);
      }
    }

    .right{
      display:flex;
      justify-content:center;
    }

    .card{
      width:100%;
      max-width:420px;
      background:rgba(255,255,255,0.08);
      border:1px solid rgba(255,255,255,0.12);
      border-radius:30px;
      padding:35px;
      backdrop-filter:blur(14px);
      box-shadow:0 10px 40px rgba(0,0,0,0.4);
    }

    .card h2{
      font-size:32px;
      margin-bottom:20px;
      text-align:center;
    }

    .feature{
      display:flex;
      align-items:center;
      gap:15px;
      margin-bottom:20px;
      padding:15px;
      border-radius:14px;
      background:rgba(255,255,255,0.05);
    }

    .feature-icon{
      width:45px;
      height:45px;
      border-radius:12px;
      background:#22c55e;
      display:flex;
      justify-content:center;
      align-items:center;
      font-size:22px;
      font-weight:bold;
    }

    .feature-text h4{
      margin-bottom:5px;
      font-size:18px;
    }

    .feature-text p{
      color:#cbd5e1;
      font-size:14px;
    }

    .footer-text{
      margin-top:25px;
      text-align:center;
      color:#94a3b8;
      font-size:13px;
      line-height:1.6;
    }

    @media(max-width:900px){

      .container{
        grid-template-columns:1fr;
      }

      .left{
        text-align:center;
      }

      .stats{
        justify-content:center;
      }

      .left h1{
        font-size:42px;
      }
    }

  </style>
</head>

<body>

<section class="hero">

  <div class="container">

    <div class="left">

      <h1>
        Join Our <span>Stock Market</span><br>
        Telegram Channel
      </h1>

      <p>
        Get educational market insights, trading psychology tips,
        stock market updates, and learning content directly on Telegram.
        Simple, professional, and beginner friendly.
      </p>

      <div class="stats">

        <div class="stat-box">
          <h3>50K+</h3>
          <span>Community Members</span>
        </div>

        <div class="stat-box">
          <h3>Daily</h3>
          <span>Market Updates</span>
        </div>

      </div>

      <a href="https://t.me/yourchannelusername" class="telegram-btn">
        🚀 JOIN TELEGRAM NOW
      </a>

    </div>

    <div class="right">

      <div class="card">

        <h2>Why Join Us?</h2>

        <div class="feature">
          <div class="feature-icon">✓</div>
          <div class="feature-text">
            <h4>Educational Content</h4>
            <p>Learn stock market basics & trading knowledge.</p>
          </div>
        </div>

        <div class="feature">
          <div class="feature-icon">✓</div>
          <div class="feature-text">
            <h4>Market Updates</h4>
            <p>Stay updated with market trends & analysis.</p>
          </div>
        </div>

        <div class="feature">
          <div class="feature-icon">✓</div>
          <div class="feature-text">
            <h4>Community Support</h4>
            <p>Connect with like-minded learners & traders.</p>
          </div>
        </div>

        <div class="footer-text">
          Disclaimer: This channel is only for educational and informational purposes.
          We do not provide financial or investment advice.
        </div>

      </div>

    </div>

  </div>

</section>

</body>
</html>